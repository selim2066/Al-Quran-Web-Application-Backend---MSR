
{
  "compilerOptions": {
    "target": "ES2023",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
 "include": [
  "src/**/*",
  "prisma.config.ts"
],
  "exclude": ["node_modules", "dist", "generated/prisma"]
}
