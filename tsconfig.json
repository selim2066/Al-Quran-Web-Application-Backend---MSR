{
  "compilerOptions": {
    "target": "ES2023",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"], // ← make sure this is ONLY src
  "exclude": ["node_modules", "dist", "prisma.config.ts"] // ← CHANGED, added prisma.config.ts
}
